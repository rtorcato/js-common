---
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const installHref = `${base}/guides/installation/`
const githubHref = 'https://github.com/rtorcato/js-common'
---

<div class="stitch-home">
	<!-- Hero -->
	<section class="hero">
		<div class="hero-glow" aria-hidden="true"></div>
		<div class="hero-grid">
			<div class="hero-copy">
				<div class="hero-badge">
					<span class="hero-badge-dot"></span>
					<span>Version 2.0 — now live</span>
				</div>
				<h1 class="hero-title">js-common</h1>
				<p class="hero-tagline">
					Tree-shakeable TypeScript utilities —
					<span class="hero-accent">tiny bundles, full type safety,</span>
					CLI included.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href={installHref}>
						Get started
						<svg
							width="18"
							height="18"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2.25"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
						</svg>
					</a>
					<a class="btn btn-ghost" href={githubHref} rel="noreferrer">
						View on GitHub
						<svg
							width="18"
							height="18"
							viewBox="0 0 24 24"
							fill="currentColor"
							aria-hidden="true"
						>
							<path
								d="m12 17.27 6.18 3.73-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"
							/>
						</svg>
					</a>
				</div>
			</div>

			<div class="hero-snippet">
				<div class="snippet-frame">
					<div class="snippet-header">
						<div class="snippet-dots" aria-hidden="true">
							<span></span><span></span><span></span>
						</div>
						<span class="snippet-file">demo.ts</span>
						<button class="snippet-copy" type="button" aria-label="Copy snippet">
							<svg
								width="16"
								height="16"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
								<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
							</svg>
						</button>
					</div>
					<pre class="snippet-code"><span class="kw">import</span> {'{'}
  <span class="fn">isEmpty</span>,
  <span class="fn">toKebabCase</span>,
  <span class="fn">sleep</span>,
  <span class="fn">deepClone</span>,
  <span class="fn">once</span>
{'}'} <span class="kw">from</span> <span class="str">'@rtorcato/js-common'</span>

<span class="kw">const</span> data = {'{'} a: <span class="obj">1</span> {'}'}
<span class="kw">const</span> copy = <span class="fn">deepClone</span>(data)

<span class="kw">await</span> <span class="fn">sleep</span>(<span class="obj">200</span>)
<span class="fn">console.log</span>(<span class="fn">toKebabCase</span>(<span class="str">'Hello World'</span>))
<span class="cmt">// hello-world</span></pre>
				</div>
				<div class="hero-mark" aria-hidden="true">js</div>
			</div>
		</div>
	</section>

	<!-- Why bento -->
	<section class="bento">
		<header class="section-header">
			<h2>Why js-common?</h2>
			<span class="rule"></span>
		</header>
		<div class="bento-grid">
			<article class="card">
				<div class="card-icon">
					<svg
						width="22"
						height="22"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
					</svg>
				</div>
				<h3>Ultra-lightweight</h3>
				<p>
					Main bundle is only <strong>~277 bytes</strong>. Individual modules
					add ~50–200 bytes each.
				</p>
			</article>

			<article class="card">
				<div class="card-icon">
					<svg
						width="22"
						height="22"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="M12 2v6" /><path d="M5 12V8h14v4" /><path d="M5 22v-6" /><path
							d="M19 22v-6"
						/><path d="M9 22h6" />
					</svg>
				</div>
				<h3>Tree-shakeable</h3>
				<p>
					Named subpath exports — <strong>import only what you need</strong> for lean
					builds.
				</p>
			</article>

			<article class="card">
				<div class="card-icon">
					<svg
						width="22"
						height="22"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path
							d="M12 2 4 5v6c0 5 3.5 9.5 8 11 4.5-1.5 8-6 8-11V5l-8-3Z"
						/><path d="m9 12 2 2 4-4" />
					</svg>
				</div>
				<h3>TypeScript-first</h3>
				<p>
					Strict types, <strong>generics preserved</strong>, JSDoc-rich in your IDE.
				</p>
			</article>

			<article class="card">
				<div class="card-icon">
					<svg
						width="22"
						height="22"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<polyline points="4 17 10 11 4 5" /><line x1="12" y1="19" x2="20" y2="19"
						/>
					</svg>
				</div>
				<h3>CLI included</h3>
				<p>
					Run utilities directly from your terminal via
					<code>npx @rtorcato/js-common</code>.
				</p>
			</article>
		</div>
	</section>

	<!-- Stats band -->
	<section class="stats">
		<div class="stats-bg" aria-hidden="true"></div>
		<div class="stats-inner">
			<h2 class="stats-title">Built for speed.</h2>
			<p class="stats-sub">
				Minimal overhead, maximum productivity. No compromises on DX or
				performance.
			</p>
			<div class="stats-row">
				<div class="stat">
					<div class="stat-value">0</div>
					<div class="stat-label">Dependencies</div>
				</div>
				<div class="stat-sep" aria-hidden="true"></div>
				<div class="stat">
					<div class="stat-value">&lt;1kb</div>
					<div class="stat-label">Average bundle</div>
				</div>
				<div class="stat-sep" aria-hidden="true"></div>
				<div class="stat">
					<div class="stat-value">100%</div>
					<div class="stat-label">Type safe</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Pull quote + checklist -->
	<section class="quote">
		<div class="quote-grid">
			<div class="quote-visual" aria-hidden="true">
				<div class="quote-visual-inner"></div>
			</div>
			<div class="quote-copy">
				<blockquote>
					"Simply the fastest way to add reliability to your project."
				</blockquote>
				<p>
					Stop rewriting the same helper functions for every new project.
					js-common provides a standardized, tested, and optimized set of tools
					that you'll actually use.
				</p>
				<ul class="checklist">
					<li>ESM &amp; CommonJS support out of the box.</li>
					<li>Battle-tested in high-traffic production environments.</li>
					<li>Zero configuration needed to get started.</li>
				</ul>
			</div>
		</div>
	</section>
</div>
