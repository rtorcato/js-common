

echo "🔍 Running pre-commit checks..."

echo "🧹 Running typecheck (pnpm run typecheck)..."
pnpm run typecheck
echo "🧹 Running lint (pnpm run check)..."
pnpm run check
CHECK_STATUS=$?

if [ $CHECK_STATUS -ne 0 ]; then
  echo "❌ Linting failed!"
  exit 1
else
  echo "✅ Linting passed!"
fi

pnpm exec biome format .

echo "🎉 Pre-commit checks passed successfully!"